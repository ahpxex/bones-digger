# ===================================================================
# 骨鉴 OSTEOGNOSIS — environment variables
# Copy to .env.local and fill in values to switch from mock to real APIs.
# ===================================================================

# --- AI provider switch --------------------------------------------
# "mock"      : no external calls, deterministic output per upload id
# "dashscope" : call Qwen3.5 via Alibaba DashScope
AI_PROVIDER=mock

# --- DashScope (Qwen3.5) -------------------------------------------
# Get keys at: https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=
# DashScope OpenAI-compatible endpoint
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Live traffic model (fast, low latency). Options:
#   qwen-vl-plus / qwen-vl-max / qwen3-vl-plus (alias rolls forward)
DASHSCOPE_VLM_MODEL=qwen3-vl-plus

# --- SAM 3.1 segmentation ------------------------------------------
# "stub"      : synthesize a soft-vignette image (no network)
# "replicate" : call real SAM 3 / 3.1 via Replicate
SAM_PROVIDER=stub
REPLICATE_API_TOKEN=
REPLICATE_SAM_VERSION=meta/sam-3
