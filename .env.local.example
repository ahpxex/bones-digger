# ===================================================================
# 骨鉴 OSTEOGNOSIS — environment variables
# Copy to .env.local and fill in values to switch from mock to real APIs.
# ===================================================================

# --- AI provider switch --------------------------------------------
# "mock"      : no external calls, deterministic output per upload id
# "dashscope" : call Qwen3.5 + Qwen3-Embedding via Alibaba DashScope
AI_PROVIDER=mock

# --- DashScope (Qwen3.5 + Qwen3-Embedding) -------------------------
# Get keys at: https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=
# OpenAI-compatible endpoint. Singapore: dashscope-intl.aliyuncs.com
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Vision-language models (dual channel) -------------------------
# Realtime channel — low latency, used for every upload.
#   qwen3.5-flash  (cheapest / fastest)
#   qwen3.5-plus   (balanced quality)
DASHSCOPE_VLM_MODEL_REALTIME=qwen3.5-flash

# Thinking channel — used when realtime confidence is low OR out-of-distribution.
# Same API, but we pass extra_body: { enable_thinking: true }.
DASHSCOPE_VLM_MODEL_THINKING=qwen3.5-plus

# Confidence threshold that triggers the thinking channel (0–1). Default 0.72.
THINKING_CHANNEL_THRESHOLD=0.72

# --- Embedding model (Qwen3-Embedding) -----------------------------
# text-embedding-v4 is Qwen3-Embedding family, 64–2048 dim.
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIM=1024

# --- Persistent production storage --------------------------------
# Required on Vercel. Connect a Vercel Blob store to the project so uploads,
# generated images, GLB meshes, and analysis JSON survive serverless runtime.
BLOB_READ_WRITE_TOKEN=

# --- SAM 3.1 segmentation ------------------------------------------
# "stub"      : synthesize a soft-vignette image (no network)
# "replicate" : call real SAM 3 / 3.1 via Replicate
SAM_PROVIDER=stub
REPLICATE_API_TOKEN=
REPLICATE_SAM_VERSION=meta/sam-3

# --- SAM 3D Objects (single-image to GLB mesh) ---------------------
# "none"      : skip 3D reconstruction (default, fast)
# "fal"       : use fal.ai hosted endpoint (FAL_KEY required)
# "replicate" : use Replicate hosted SAM 3D (REPLICATE_API_TOKEN required)
# "stub"      : placeholder mesh only (no network call)
SAM3D_PROVIDER=none
FAL_KEY=
REPLICATE_SAM3D_VERSION=facebookresearch/sam-3d-objects
